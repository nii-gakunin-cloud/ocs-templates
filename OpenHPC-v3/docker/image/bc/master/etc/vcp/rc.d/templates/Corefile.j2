# Corefile for OpenHPC cluster DNS
# Generated by: 20-coredns.sh

# クラスタ内部ドメイン（hostsプラグインを使用）
{{ environ("DNS_DOMAIN") | default("ohpc.internal") }}:53 {
    bind {{ environ("MASTER_IP") }}
    log
    errors
    hosts /opt/ohpc/pub/etc/hosts.ohpc {
        ttl 60
        reload 5s
        fallthrough
    }
{% if environ("DNS_FORWARDERS") -%}
    forward . {{ environ("DNS_FORWARDERS") | replace(",", " ") }}
{% else -%}
    forward . 8.8.8.8 8.8.4.4
{%- endif %}
}

# 外部ドメインへの転送
.:53 {
    bind {{ environ("MASTER_IP") }}
    log
    errors
{% if environ("DNS_FORWARDERS") -%}
    forward . {{ environ("DNS_FORWARDERS") | replace(",", " ") }}
{% else -%}
    forward . 8.8.8.8 8.8.4.4
{%- endif %}
    cache 30
}
